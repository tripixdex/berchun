<pre class=3D"eListing">stan1 storage 1
stan2 storage 1
stan3 storage 1
      generate   10,3         ;one segment
      queue astan1
      enter stan1
      depart astan1
      advance    16,4
      leave stan1

      queue astan3
      enter stan3
      depart astan3
      advance    9,4
      leave stan3

      queue astan2
      enter stan2
      depart astan2
      advance    15,6
      leave stan2
      terminate

      generate   12,5         ;two segment
      queue astan2
      enter stan2
      depart astan2
      advance    6,2
      leave stan2

      queue astan1
      enter stan1
      depart astan1
      advance    25,4
      leave stan1
</pre>
<pre class=3D"eListing">      queue astan3
      enter stan3
      depart astan3
      advance    10,3
      leave stan3
      terminate

      generate 480
      terminate 1

</pre>
